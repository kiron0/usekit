{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "description": "A useKit registry of hooks.",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the registry."
    },
    "homepage": {
      "type": "string",
      "description": "The homepage URL for the registry."
    },
    "items": {
      "type": "array",
      "description": "The registry items included in this registry.",
      "items": {
        "$ref": "https://usekit.vercel.app/schema/registry-item.json"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "required": ["name", "homepage", "items"],
  "additionalProperties": false
}
